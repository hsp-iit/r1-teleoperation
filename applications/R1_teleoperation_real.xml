<application>
   <name>R1_teleoperation_REAL</name>
   <dependencies>
   </dependencies>

	
   <!-- modules -->

    <module>
        <name>yarprobotinterface</name>
        <parameters></parameters>
        <workdir>$ENV{ROBOT_CODE}/robots-configuration/R1SN003/</workdir>
        <node>r1-base</node>
     </module>
     <module>
        <name>yarprobotinterface</name>
        <parameters>--context navigation2 --from realsense2_ir.ini</parameters>
        <node>r1-torso</node>
     </module>
    
    <module>
       <name>yarprobotinterface</name>
       <parameters>--context navigation2 --from lidar_compressed.ini</parameters>
       <node>console</node>
    </module>
 
    <module>
       <name>ros2_launch.sh</name>
       <parameters>robot_state_publisher_R1SN003.launch.py</parameters>
       <workdir>$ENV{TOUR_GUIDE_ROBOT_SOURCE_DIR}/app/navigation2/launch/</workdir>
       <node>r1-base</node>
    </module>
 
    <!-- Frame for external realsense -->
    <module>
       <name>ros2_run.sh</name>
       <parameters>tf2_ros static_transform_publisher 0 -0.05 0 0 0 0 1 depth_center extra_camera_tf</parameters>
       <node>r1-base</node>
    </module>
 
    <module>
       <name>baseControl2</name>
       <parameters>--context baseControl2 --from baseCtrl_cer_ros2.ini --skip_robot_interface_check</parameters>
       <node>r1-base</node>
    </module>

    <module>
          <name>./set_home_position.sh</name>
          <parameters></parameters>
          <workdir>/home/user/</workdir>
          <node>ecc-base</node>
    </module>
    
           
   <module>
      <name>mc-ergocub-cartesian-bimanual</name>
      <parameters>--from config_r1.ini</parameters>
      <environment></environment>
      <workdir>/home/user/ergocub-cartesian-control/src/ergocub_cartesian_bimanual/app/conf/real/</workdir>
      <node>ecc-base</node>
   </module>

   <module>
         <name>mc-ergocub-head-controller</name>
         <parameters>--from config_r1.ini</parameters>
         <environment></environment>
         <workdir>/home/user/ergocub-cartesian-control/src/ergocub_head_controller/app/conf/</workdir>
         <node>ecc-base</node>
      </module>

    <module>
      <name>ergocub-finger-controller</name>
      <parameters>--from r1_finger_controller.ini</parameters>
      <environment></environment>
      <workdir>/home/user/ergocub-cartesian-control/src/ergocub_finger_controller/config/</workdir>
      <node>ecc-base</node>
   </module>

    <module>
        <tag>frameTransformerServer</tag>
        <name>yarpdev</name>
        <node>win</node>
        <parameters>--device frameTransformServer --filexml_option fts_yarp_only.xml</parameters>
    </module>
    <module>
        <tag>openxrheadset</tag>
        <name>yarprobotinterface</name>
        <node>win</node>
        <parameters>--config C:\Users\metac\metaCub\xml\applications\joystick_device.xml</parameters>
        <depends>frameTransformerServer</depends>
    </module>
    <module>
        <tag>OpenXrFrameViz</tag>
        <name>OpenXrFrameViz</name>
        <node>win</node>
        <depends>openxrheadset</depends>
    </module>
	

   <!-- connections -->
   <connection>
       <from>/depthCamera/ir:o</from>
       <to>/meta/joypad/display:i</to>
       <protocol>mjpeg</protocol>
   </connection>
   <connection>
       <from>/joystickCtrl:o</from>
       <to>/baseControl/input/joystick/data:i</to>
       <protocol>tcp+recv.portmonitor+type.dll+file.joy2vel</protocol>
   </connection>
	   
</application>
